// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum Role {
  ADMIN
  RECEPTION
  SECTOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(SECTOR)
  sectorId  String?  @unique // Nullable for RECEPTION and ADMIN
  sector    Sector?  @relation(fields: [sectorId], references: [id])
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sector {
  id           String   @id @default(uuid())
  name         String   @unique
  status              String   @default("AVAILABLE") // AVAILABLE | BUSY | AWAY
  queueCount          Int      @default(0)
  soundUrl            String?  // URL do áudio de chamada específico do setor
  callCooldown        Int      @default(120) // Tempo em segundos de espera mandatória entre cada chamada
  hasWaitingRoom      Boolean  @default(false)
  waitingRoomCapacity Int      @default(5)
  isHeterogeneous     Boolean  @default(false)
  isVisibleOnPanel    Boolean  @default(true)
  resources           Resource[]
  user                User?
  visits              Visit[]
  entryLogs           EntryLog[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, sectorId])
}

model Citizen {
  cpf       String   @id
  name      String
  phone     String?
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id                    String   @id @default(uuid())
  code                  String?  @unique  // Código único do ticket ex: A-045
  ticketStatus          String?  @default("WAITING") // WAITING | IN_WAITING_ROOM | IN_SERVICE | FINISHED
  isPriority            Boolean  @default(false)
  citizenId             String
  citizen               Citizen  @relation(fields: [citizenId], references: [cpf])
  sectorId              String
  sector                Sector   @relation(fields: [sectorId], references: [id])
  resourceId            String?
  resource              Resource? @relation(fields: [resourceId], references: [id])
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id])
  calledToWaitingRoomAt DateTime? 
  calledAt              DateTime? 
  finishedAt            DateTime? 
  timestamp             DateTime @default(now())
}

model EntryLog {
  id        String   @id @default(uuid())
  cpf       String
  name      String
  phone     String?
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id])
  timestamp DateTime @default(now())
}
