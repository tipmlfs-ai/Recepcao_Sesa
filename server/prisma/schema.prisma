// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ADMIN
  RECEPTION
  SECTOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(SECTOR)
  sectorId  String?  @unique // Nullable for RECEPTION and ADMIN
  sector    Sector?  @relation(fields: [sectorId], references: [id])
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sector {
  id           String   @id @default(uuid())
  name         String   @unique
  status       String   @default("AVAILABLE") // AVAILABLE | BUSY | AWAY
  queueCount   Int      @default(0)
  soundUrl     String?  // URL do áudio de chamada específico do setor
  callCooldown Int      @default(120) // Tempo em segundos de espera mandatória entre cada chamada
  user         User?
  visits       Visit[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Citizen {
  cpf       String   @id
  name      String
  phone     String?
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id           String   @id @default(uuid())
  code         String?  @unique  // Código único do ticket ex: A-045
  ticketStatus String?  @default("WAITING") // WAITING | IN_SERVICE | FINISHED
  citizenId    String
  citizen      Citizen  @relation(fields: [citizenId], references: [cpf])
  sectorId     String
  sector       Sector   @relation(fields: [sectorId], references: [id])
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  timestamp    DateTime @default(now())
}
